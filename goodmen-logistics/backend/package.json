{
  "name": "goodmen-logistics-backend",
  "version": "1.0.0",
  "description": "Goodmen Logistics Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "node database/init.js",
    "db:reset": "node database/reset.js",
    "db:schema": "node database/run-schema.js",
    "db:seed": "node database/run-seed.js",
    "db:status": "node database/status.js",
    "migrate:dev": "npx knex migrate:latest --env development",
    "migrate:prod": "npx knex migrate:latest --env production"
  },
  "keywords": [
    "logistics",
    "fmcsa",
    "compliance"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@goodmen/shared": "file:../../packages/goodmen-shared",
    "@aws-sdk/client-s3": "^3.967.0",
    "@aws-sdk/s3-request-presigner": "^3.967.0",
    "@sendgrid/mail": "^8.1.0",
    "axios": "^1.13.4",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.4",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "multer": "^2.0.2",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.16.0",
    "pg": "^8.18.0",
    "twilio": "^5.0.0",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
