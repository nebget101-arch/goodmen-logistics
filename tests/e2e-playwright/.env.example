# ============================================================================
# Playwright E2E (Phase 1 smoke) — environment variables
# ============================================================================
# Copy this file to `.env` for local runs. NEVER commit `.env`.
#
# In CI (GitHub Actions on the FleetNeuronAPP repo) the same variable names
# are provided as GitHub Actions repository secrets — see "GitHub Actions
# secrets" below for the authoritative list and provisioning steps.
#
# These credentials are deliberately NOT stored in Render service envs:
# the gateway and microservices must not know about test users.
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Smoke-suite test account (FN-970)
# ----------------------------------------------------------------------------
# Account `qa-smoke@fleetneuron.test` is seeded into the dev auth-users DB by
# the FN-985 migration with a full-permission role so the smoke suite can
# traverse every NAV_TOP_LINKS / NAV_SECTIONS / user-menu route without
# hitting permission redirects.
#
# Used by Playwright `globalSetup` to perform programmatic API login against
# `${PLAYWRIGHT_BASE_URL}/api/auth/login` and persist the resulting JWT into
# `storageState.json` for the auth fixture.

QA_SMOKE_USER=qa-smoke@fleetneuron.test
QA_SMOKE_PASSWORD=replace-with-dev-secret

# ----------------------------------------------------------------------------
# Target environment
# ----------------------------------------------------------------------------
# Base URL the smoke suite hits. Defaults to dev gateway in CI.
PLAYWRIGHT_BASE_URL=https://fleetneuron-logistics-gateway.onrender.com

# ============================================================================
# GitHub Actions secrets (CI source of truth)
# ============================================================================
# Required repository secrets on `nebget101-arch/goodmen-logistics`:
#
#   QA_SMOKE_USER      — value: qa-smoke@fleetneuron.test
#   QA_SMOKE_PASSWORD  — value: <password set by FN-985 migration on dev>
#
# Provisioning (one-time, by repo admin):
#   GitHub repo → Settings → Secrets and variables → Actions → New repository
#   secret. Add both names with the values above.
#
# Rotation:
#   1. Update the password on the dev auth-users DB (re-run FN-985 seed with
#      a new value or run a manual UPDATE on `users` for the qa-smoke account).
#   2. Update the `QA_SMOKE_PASSWORD` GitHub Actions secret to match.
#   3. Re-run any in-flight Playwright smoke workflow.
#
# DO NOT add these to Render env vars on any backend service.
