# API Gateway – copy to .env and set values
# Development (defaults used if omitted)
PORT=4000
TARGET_BACKEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:4200

# Production: set these for your deployment
# PORT=4000
# TARGET_BACKEND_URL=https://your-backend.example.com
# CORS_ORIGIN=https://your-frontend.example.com
# NODE_ENV=production
