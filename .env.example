# ============================================================================
# Twilio Configuration - Voice Calls for Roadside AI
# ============================================================================
# Get these from https://www.twilio.com/console

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Webhook base URL for Twilio callbacks
# Must be publicly accessible HTTPS URL
TWILIO_TWIML_URL=https://your-domain.com/webhooks/twilio/call

# ============================================================================
# SendGrid Configuration - Email Notifications
# ============================================================================
# Get API key from https://app.sendgrid.com/settings/api_keys

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=FleetNeuron AI <roadside@your-domain.com>

# ============================================================================
# Public App URLs
# ============================================================================

PUBLIC_APP_BASE_URL=https://your-domain.com
APP_BASE_URL=http://localhost:4200

# Full URL of the deployed reset-password page used to build password-reset email
# links (FN-1729). If unset, auth.js derives `${PUBLIC_APP_BASE_URL or
# APP_BASE_URL}/reset-password`, falling back to localhost in dev. Set this on
# fleetneuron-auth-users-service (prod: https://fleetneuron.ai/reset-password,
# dev: https://dev.fleetneuron.ai/reset-password) so reset emails never point at
# localhost.
PASSWORD_RESET_URL_BASE=http://localhost:4200/reset-password

# ============================================================================
# Dispatcher Configuration (Optional)
# ============================================================================

# Comma-separated dispatcher emails for new call notifications
ROADSIDE_DISPATCHER_EMAILS=dispatcher1@company.com,dispatcher2@company.com

# ============================================================================
# Database Configuration
# ============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_USER=goodmen
DB_PASSWORD=your_password
DB_NAME=fleetneuron

# ============================================================================
# AWS/Cloudflare R2 Configuration (Media Storage)
# ============================================================================

AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_BUCKET=roadside-media
R2_ACCESS_KEY_ID=your_r2_key
R2_SECRET_ACCESS_KEY=your_r2_secret

# ----------------------------------------------------------------------------
# Incident image storage (FN-1195 / FN-1233) — Cloudflare R2, S3-compatible API
# ----------------------------------------------------------------------------
# Read by backend/packages/goodmen-shared/storage/r2-storage.js and
# incident-images.service.js. The S3 client endpoint is derived from
# R2_ACCOUNT_ID (https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com) — there is no
# separate endpoint var for this path. R2_ACCOUNT_ID / R2_ACCESS_KEY_ID /
# R2_SECRET_ACCESS_KEY / R2_BUCKET are REQUIRED (the service throws on startup of
# the first upload if any is missing). Provision per environment and set the
# secrets in the Render dashboard — never commit real values.
#
# Bucket naming convention (see docs/runbooks/incident-image-storage.md):
#   dev      -> fleetneuron-incident-images-dev
#   staging  -> fleetneuron-incident-images-staging
#   prod     -> fleetneuron-incident-images-prod
R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_BUCKET / R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY reuse the vars above; point
# them at the incident-images bucket + its scoped API token for this environment.
R2_REGION=auto
# Pre-signed GET URL lifetime in seconds. INCIDENT_IMAGE_SIGNED_URL_TTL wins for
# incident images; R2_SIGNED_URL_EXPIRES_SECONDS is the generic storage fallback.
INCIDENT_IMAGE_SIGNED_URL_TTL=900
R2_SIGNED_URL_EXPIRES_SECONDS=900

# ============================================================================
# Application Configuration
# ============================================================================

NODE_ENV=production
LOG_LEVEL=info

# Port for API server
PORT=3000

# JWT Secret for token generation
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=7d

# ============================================================================
# Redis Configuration (Optional - for caching/sessions)
# ============================================================================

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=optional_password

# ============================================================================
# Feature Flags
# ============================================================================

ENABLE_TWILIO_CALLS=true
ENABLE_SENDGRID_EMAILS=true
ENABLE_CALL_RECORDING=true
ENABLE_REVERSE_GEOCODING=true

# ============================================================================
# AI Configuration
# ============================================================================

# OpenAI API key for AI assessments
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI Model name for roadside triage
ROADSIDE_AI_MODEL=gpt-4
ROADSIDE_AI_PROMPT_VERSION=1.0

# ============================================================================
# FMCSA API Configuration (FN-101)
# ============================================================================
# Free API key — register at: https://mobile.fmcsa.dot.gov/developer/apidataguidance
# Used server-side only to proxy USDOT carrier lookups on the trial signup form.
# This key is NEVER sent to the browser.
FMCSA_API_KEY=your_fmcsa_api_key_here

# ============================================================================
# Stripe Billing Configuration (FN-71)
# ============================================================================
# Secret API key from Stripe Dashboard (Developers > API keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Webhook signing secret from Stripe Dashboard (Developers > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Stripe Price IDs for FleetNeuron subscription plans
STRIPE_PRICE_BASIC=price_basic_placeholder
STRIPE_PRICE_MULTI_MC=price_multi_mc_placeholder
STRIPE_PRICE_END_TO_END=price_end_to_end_placeholder
STRIPE_PRICE_ENTERPRISE=price_enterprise_placeholder

# Recurring add-on: each unit = one extra user seat / month (FN-134)
STRIPE_PRICE_EXTRA_USER_SEAT=price_extra_user_seat_placeholder

# ============================================================================
# OpenTelemetry / SigNoz Observability (Self-Hosted)
# ============================================================================
# Self-hosted SigNoz on Render — see infra/signoz/README.md
# For local dev with docker-compose, use the local collector URL:
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# For Render production, use the OTel Collector service URL:
# OTEL_EXPORTER_OTLP_ENDPOINT=https://signoz-otel-collector-fleetneuron.onrender.com
OTEL_SERVICE_NAME=fleetneuron-local-dev

# ============================================================================
# Telematics ingestion — Samsara + Motive (FN-1653)
# ============================================================================
# Consumed by fleetneuron-integrations-service (webhook ingress + polling fallback).
# Provider REST API tokens — used by the polling fallback to pull last position.
TELEMATICS_SAMSARA_API_TOKEN=your_samsara_api_token
TELEMATICS_MOTIVE_API_TOKEN=your_motive_api_token
# Generic shared secret gating the ?secret=<...> query param on the webhook URL
# (POST /api/webhooks/telematics/:provider?secret=<this>). Generate: openssl rand -hex 32
TELEMATICS_WEBHOOK_SECRET=your_telematics_webhook_secret
# Per-provider HMAC signing secrets — verify the provider's signature header.
TELEMATICS_WEBHOOK_SECRET_SAMSARA=your_samsara_signing_secret
TELEMATICS_WEBHOOK_SECRET_MOTIVE=your_motive_signing_secret
# Polling fallback: minutes between in-process scheduler runs (omit to disable and
# rely on an external cron hitting POST /api/telematics/poll instead).
TELEMATICS_POLL_INTERVAL_MINUTES=10

# ============================================================================
# Real-time WebSocket + SMS internal wiring (FN-1198 / FN-1242)
# ============================================================================
# Shared secret for the gateway's /internal/ws/emit endpoint.
# Must be set on BOTH the gateway and drivers-compliance services.
# Generate: openssl rand -hex 32
INTERNAL_WS_SECRET=your_internal_ws_secret_here

# URL of the gateway service reachable from drivers-compliance.
# Local dev: http://localhost:4000
# Render production: https://fleetneuron-logistics-gateway.onrender.com
INTERNAL_GATEWAY_URL=http://localhost:4000
