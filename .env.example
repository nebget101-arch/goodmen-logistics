# ============================================================================
# Twilio Configuration - Voice Calls for Roadside AI
# ============================================================================
# Get these from https://www.twilio.com/console

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Webhook base URL for Twilio callbacks
# Must be publicly accessible HTTPS URL
TWILIO_TWIML_URL=https://your-domain.com/webhooks/twilio/call

# ============================================================================
# SendGrid Configuration - Email Notifications
# ============================================================================
# Get API key from https://app.sendgrid.com/settings/api_keys

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=FleetNeuron AI <roadside@your-domain.com>

# ============================================================================
# Public App URLs
# ============================================================================

PUBLIC_APP_BASE_URL=https://your-domain.com
APP_BASE_URL=http://localhost:4200

# ============================================================================
# Dispatcher Configuration (Optional)
# ============================================================================

# Comma-separated dispatcher emails for new call notifications
ROADSIDE_DISPATCHER_EMAILS=dispatcher1@company.com,dispatcher2@company.com

# ============================================================================
# Database Configuration
# ============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_USER=goodmen
DB_PASSWORD=your_password
DB_NAME=fleetneuron

# ============================================================================
# AWS/Cloudflare R2 Configuration (Media Storage)
# ============================================================================

AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_BUCKET=roadside-media
R2_ACCESS_KEY_ID=your_r2_key
R2_SECRET_ACCESS_KEY=your_r2_secret

# ============================================================================
# Application Configuration
# ============================================================================

NODE_ENV=production
LOG_LEVEL=info

# Port for API server
PORT=3000

# JWT Secret for token generation
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=7d

# ============================================================================
# Redis Configuration (Optional - for caching/sessions)
# ============================================================================

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=optional_password

# ============================================================================
# Feature Flags
# ============================================================================

ENABLE_TWILIO_CALLS=true
ENABLE_SENDGRID_EMAILS=true
ENABLE_CALL_RECORDING=true
ENABLE_REVERSE_GEOCODING=true

# ============================================================================
# AI Configuration
# ============================================================================

# OpenAI API key for AI assessments
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI Model name for roadside triage
ROADSIDE_AI_MODEL=gpt-4
ROADSIDE_AI_PROMPT_VERSION=1.0

# ============================================================================
# FMCSA API Configuration (FN-101)
# ============================================================================
# Free API key — register at: https://mobile.fmcsa.dot.gov/developer/apidataguidance
# Used server-side only to proxy USDOT carrier lookups on the trial signup form.
# This key is NEVER sent to the browser.
FMCSA_API_KEY=your_fmcsa_api_key_here

# ============================================================================
# Stripe Billing Configuration (FN-71)
# ============================================================================
# Secret API key from Stripe Dashboard (Developers > API keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Webhook signing secret from Stripe Dashboard (Developers > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Stripe Price IDs for FleetNeuron subscription plans
STRIPE_PRICE_BASIC=price_basic_placeholder
STRIPE_PRICE_MULTI_MC=price_multi_mc_placeholder
STRIPE_PRICE_END_TO_END=price_end_to_end_placeholder
STRIPE_PRICE_ENTERPRISE=price_enterprise_placeholder

# Recurring add-on: each unit = one extra user seat / month (FN-134)
STRIPE_PRICE_EXTRA_USER_SEAT=price_extra_user_seat_placeholder
